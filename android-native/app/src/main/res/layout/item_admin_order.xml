<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:layout_marginBottom="12dp"
    android:padding="0dp"
    android:elevation="2dp">

    <!-- Top row: image + info + delete -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Product image -->
        <ImageView
            android:id="@+id/ivProduct"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_input"
            android:contentDescription="Product image" />

        <!-- Info column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <!-- Bill ID badge -->
            <TextView
                android:id="@+id/tvBillId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORD-001"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/bg_chip"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone"
                android:layout_marginBottom="4dp" />

            <!-- Product title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Title"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Customer name -->
            <TextView
                android:id="@+id/tvCustomerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"
                android:drawablePadding="4dp"
                android:visibility="gone" />

            <!-- Customer phone -->
            <TextView
                android:id="@+id/tvCustomerPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="1dp"
                android:visibility="gone" />

            <!-- Qty · Price · Date -->
            <TextView
                android:id="@+id/tvMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Qty: 1  •  ₹0"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />

            <!-- Note -->
            <TextView
                android:id="@+id/tvNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textStyle="italic"
                android:textColor="@color/text_hint"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="2dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Delete button (hidden - admin can only change status) -->
        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="top"
            android:src="@drawable/ic_delete"
            android:background="@drawable/bg_outline_red"
            android:padding="8dp"
            android:contentDescription="Delete"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp" />

    <!-- Status chips -->
    <LinearLayout
        android:id="@+id/statusChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

</LinearLayout>
