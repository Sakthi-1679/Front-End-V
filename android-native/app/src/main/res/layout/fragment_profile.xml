<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Avatar Hero -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardRole"
            android:layout_width="90dp"
            android:layout_height="90dp"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="@color/primary_light"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_person"
                android:contentDescription="Avatar" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/brand_dark"
            android:layout_marginTop="14dp" />

        <TextView
            android:id="@+id/tvRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customer"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:background="@drawable/bg_chip"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Info Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Email -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                    <requestFocus /></TextView>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="EMAIL" android:textSize="10sp" android:textStyle="bold"
                        android:textColor="@color/text_hint" android:letterSpacing="0.08" />
                    <TextView android:id="@+id/tvEmail" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="email" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="@color/text_primary" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <!-- Phone -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PHONE" android:textSize="10sp" android:textStyle="bold"
                        android:textColor="@color/text_hint" android:letterSpacing="0.08" />
                    <TextView android:id="@+id/tvPhone" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="phone" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="@color/text_primary" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <!-- Area -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="AREA" android:textSize="10sp" android:textStyle="bold"
                        android:textColor="@color/text_hint" android:letterSpacing="0.08" />
                    <TextView android:id="@+id/tvArea" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="area" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="@color/text_primary" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <!-- City -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CITY" android:textSize="10sp" android:textStyle="bold"
                        android:textColor="@color/text_hint" android:letterSpacing="0.08" />
                    <TextView android:id="@+id/tvCity" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="city" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="@color/text_primary" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Logout -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_logout_btn"
        android:text="Sign Out"
        android:textColor="@color/error"
        android:textSize="15sp"
        android:textStyle="bold"
        android:stateListAnimator="@null" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="VKM Flowers • Kanchipuram"
        android:textColor="@color/divider"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:padding="20dp" />

</LinearLayout>
