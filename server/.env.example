# ── Required ──────────────────────────────────────────
# Brevo (Sendinblue) API key – obtain from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# Admin e-mail address that receives new-order notifications
ADMIN_EMAIL=vkmflowerskpm@gmail.com

# Secret used to sign JWT tokens (use a long random string in production)
JWT_SECRET=change_me_in_production

# Port the Express server listens on
PORT=3001
