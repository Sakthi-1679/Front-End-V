
# Brevo (Sendinblue) – Email notifications
# Sign up free at https://www.brevo.com (300 emails/day free)

# Your Brevo v3 API key (Settings → SMTP & API → API Keys)
BREVO_API_KEY=your_brevo_api_key_here

# A verified sender address in your Brevo account
BREVO_SENDER_EMAIL=your-verified-sender@example.com

# (Optional) Display name shown in the "From" field
BREVO_SENDER_NAME=VKM Flower Shop
